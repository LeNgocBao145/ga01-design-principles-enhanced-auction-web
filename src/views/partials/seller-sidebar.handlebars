<div class="card shadow-sm border-0">
  <div class="card-body text-center pt-4 pb-3">
    <div class="position-relative d-inline-block">
      <img src="https://ui-avatars.com/api/?name={{authUser.fullname}}&background=random&size=128" 
           class="rounded-circle mb-3 shadow-sm" 
           width="100" height="100" 
           style="object-fit: cover;">
      
      <span class="position-absolute bottom-0 start-100 translate-middle badge rounded-pill bg-success border border-white text-capitalize">
        {{authUser.role}}
      </span>
    </div>

    <h5 class="card-title fw-bold mb-1">{{authUser.fullname}}</h5>
    <div class="text-muted small text-break px-3">{{authUser.email}}</div>
  </div>
  
  <div class="list-group list-group-flush profile-nav small">
   {{!-- 1. Dashboard --}}
    {{> item-sidebar url="/seller" sectionName="dashboard" icon="bi-speedometer2" title="Dashboard"}}
    
    {{!-- 2. All Products --}}
    {{> item-sidebar url="/seller/products" sectionName="all-products" icon="bi-box-seam" title="All Products"}}

    {{!-- 3. Active Products --}}
    {{> item-sidebar url="/seller/products/active" sectionName="active-products" icon="bi-play-circle" title="Active"}}

    {{!-- 4. Pending Products --}}
    {{> item-sidebar url="/seller/products/pending" sectionName="pending-products" icon="bi-hourglass-split" title="Pending"}}

    {{!-- 5. Sold Products --}}
    {{> item-sidebar url="/seller/products/sold" sectionName="sold-products" icon="bi-bag-check" title="Sold"}}

    {{!-- 6. Expired Products --}}
    {{> item-sidebar url="/seller/products/expired" sectionName="expired-products" icon="bi-x-circle" title="Expired"}}
    
    <hr class="my-2">
    {{!-- 7. Account Settings --}}
    {{> item-sidebar url="/account/profile" sectionName="profile" icon="bi-person-gear" title="Account Settings"}}

    <form id="formLogout" action="/account/logout" method="POST"></form>
    <a class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-2 text-danger fw-bold" 
       href="javascript: $('#formLogout').submit()">
      <i class="bi bi-box-arrow-right fs-5"></i> 
      <span>Sign Out</span>
    </a>

  </div>
</div>
