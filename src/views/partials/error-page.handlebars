<div class="container mt-5 mb-5">
  <div class="card shadow-sm">
    <div class="card-header {{headerColor}}">
      <h5 class="mb-0"><i class="bi {{headerIcon}} me-2"></i>{{errorCode}}</h5>
    </div>
    <div class="card-body text-center py-5">
      <i class="bi {{bigIcon}}" style="font-size: 5rem; opacity: 0.3;"></i>
      <h4 class="card-title mt-4 mb-3">{{title}}</h4>
      <p class="card-text text-muted mb-4">{{message}}</p>
      <a href="/" class="btn btn-primary">
        <i class="bi bi-house-door me-2"></i>Return to Home
      </a>
    </div>
  </div>
</div>