<div class="card shadow-sm border-0">
  <div class="card-body text-center pt-4 pb-3">
    <div class="position-relative d-inline-block">
      <img src="https://ui-avatars.com/api/?name={{authUser.fullname}}&background=random&size=128" 
           class="rounded-circle mb-3 shadow-sm" 
           width="100" height="100" 
           style="object-fit: cover;">
      
      <span class="position-absolute bottom-0 start-100 translate-middle badge rounded-pill {{#if (eq authUser.role 'seller')}}bg-success{{else}}bg-secondary{{/if}} border border-white text-capitalize">
        {{authUser.role}}
      </span>
    </div>

    <h5 class="card-title fw-bold mb-1">{{authUser.fullname}}</h5>
    <div class="text-muted small text-break px-3">{{authUser.email}}</div>
  </div>
  
  <div class="list-group list-group-flush profile-nav small">
    
    {{!-- 1. Account Settings --}}
    {{> item-sidebar url="/account/profile" sectionName="profile" icon="bi-person-gear" title="Account Settings"}}
    
    {{!-- 2. My Ratings --}}
    {{> item-sidebar url="/account/ratings" sectionName="ratings" icon="bi-star-fill" title="My Ratings"}}
    
    {{!-- 3. My Watchlist --}}
    {{> item-sidebar url="/account/watchlist" sectionName="watchlist" icon="bi-heart" title="My Watchlist"}}

    {{!-- 4. Bidding Products --}}
    {{> item-sidebar url="/account/bidding" sectionName="bidding" icon="bi-hammer" title="Bidding Products"}}

    {{!-- 5. Won Auctions --}}
    {{> item-sidebar url="/account/auctions" sectionName="auctions" icon="bi-trophy" title="Won Auctions"}}

    {{!-- 6. Logic kiểm tra Role (Seller / User) --}}
    {{#if (eq authUser.role 'seller')}}
       <div class="list-group-item py-3 d-flex align-items-center gap-2 text-success bg-success-subtle fw-bold">
           <i class="bi bi-check-circle-fill fs-5"></i> 
           <span>You are a Seller</span>
       </div>
       {{!-- Menu Seller Center --}}
       {{> item-sidebar url="/seller/" sectionName="my-products" icon="bi-box-seam" title="Seller Center"}}
       
    {{else}}
       {{!-- Menu Yêu cầu nâng cấp tài khoản --}}
       {{> item-sidebar url="/account/request-upgrade" sectionName="upgrade" icon="bi-briefcase" title="Upgrade to Seller" extraClass="text-primary fw-bold"}}
    {{/if}}
    
    <form id="formLogout" action="/account/logout" method="POST"></form>
    <a class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-2 text-danger fw-bold" 
       href="javascript: $('#formLogout').submit()">
      <i class="bi bi-box-arrow-right fs-5"></i> 
      <span>Sign Out</span>
    </a>

  </div>
</div>