<div class="card shadow-sm border-0">
  <div class="card-body text-center pt-4 pb-3">
    <div class="position-relative d-inline-block">
      {{!-- Avatar Admin: Nền đỏ (dc3545) --}}
      <img src="https://ui-avatars.com/api/?name={{authUser.fullname}}&background=dc3545&color=fff&size=128" 
           class="rounded-circle mb-3 shadow-sm" 
           width="100" height="100" 
           style="object-fit: cover;">
      
      <span class="position-absolute bottom-0 start-100 translate-middle badge rounded-pill bg-danger border border-white text-capitalize">
        Administrator
      </span>
    </div>

    <h5 class="card-title fw-bold mb-1">{{authUser.fullname}}</h5>
    <div class="text-muted small text-break px-3">{{authUser.email}}</div>
  </div>
  
  <div class="list-group list-group-flush profile-nav small">
    {{!-- 1. Account Settings --}}
    {{> item-sidebar url="/admin/account/profile" sectionName="profile" icon="bi-person-gear" title="Account Settings"}}
    
    {{!-- 2. Quản lý danh mục (4.1) --}}
    {{> item-sidebar url="/admin/categories/list" sectionName="categories" icon="bi-tags" title="Manage Categories"}}

    {{!-- 3. Quản lý sản phẩm (4.2) --}}
    {{> item-sidebar url="/admin/products/list" sectionName="products" icon="bi-box-seam" title="Manage Products"}}

    {{!-- 4. Quản lý người dùng (4.3) --}}
    {{!-- Bao gồm: Xem danh sách, Xoá, Sửa, và DUYỆT NÂNG CẤP --}}
    {{> item-sidebar url="/admin/users/list" sectionName="users" icon="bi-people" title="Manage Users"}}

    {{!-- 5. System Settings --}}
    {{> item-sidebar url="/admin/system/settings" sectionName="settings" icon="bi-gear" title="System Settings"}}

    {{!-- Logout --}}
    <form id="formAdminLogout" action="/account/logout" method="POST"></form>
    <a class="list-group-item list-group-item-action py-3 d-flex align-items-center gap-2 text-danger fw-bold mt-2 border-top" 
       href="javascript: $('#formAdminLogout').submit()">
      <i class="bi bi-box-arrow-right fs-5"></i> 
      <span>Sign Out</span>
    </a>
  </div>
</div>