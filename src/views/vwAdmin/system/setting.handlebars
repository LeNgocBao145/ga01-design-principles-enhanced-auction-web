{{#section 'css'}}
<link rel="stylesheet" href="/css/admin/system/setting.css">
<link rel="stylesheet" href="/static/css/admin/admin-global.css">

{{/section}}

{{#section 'js'}}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    $(document).ready(function() {
        // Validation form trước khi submit
        $('#formSystemSettings').on('submit', function(e) {
            e.preventDefault();
            
            const newProductLimit = parseInt($('#txtNewProductLimit').val());
            const autoExtendTrigger = parseInt($('#txtAutoExtendTrigger').val());
            const autoExtendDuration = parseInt($('#txtAutoExtendDuration').val());
            
            // Validation
            if (!newProductLimit || newProductLimit < 1) {
                Swal.fire({
                    icon: 'error',
                    title: 'Validation Error',
                    text: 'New Product Limit must be greater than 0!'
                });
                return false;
            }
            
            if (!autoExtendTrigger || autoExtendTrigger < 1) {
                Swal.fire({
                    icon: 'error',
                    title: 'Validation Error',
                    text: 'Auto Extend Trigger must be greater than 0!'
                });
                return false;
            }
            
            if (!autoExtendDuration || autoExtendDuration < 1) {
                Swal.fire({
                    icon: 'error',
                    title: 'Validation Error',
                    text: 'Auto Extend Duration must be greater than 0!'
                });
                return false;
            }

            // Confirm before saving
            Swal.fire({
                title: 'Confirm Changes',
                html: `
                    <div class="text-start">
                        <p class="mb-2"><strong>New Product Limit:</strong> ${newProductLimit} minutes</p>
                        <p class="mb-2"><strong>Auto Extend Trigger:</strong> ${autoExtendTrigger} minutes</p>
                        <p class="mb-0"><strong>Auto Extend Duration:</strong> ${autoExtendDuration} minutes</p>
                    </div>
                `,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Yes, save settings!'
            }).then((result) => {
                if (result.isConfirmed) {
                    this.submit();
                }
            });
        });

        // Show success message if exists
        {{#if success_message}}
        Swal.fire({
            icon: 'success',
            title: 'Success!',
            text: '{{success_message}}',
            timer: 2000,
            showConfirmButton: false
        });
        {{/if}}
    });
</script>
{{/section}}

<div class="container-fluid mt-4 mb-5">
  <div class="row">
    
    <!-- SIDEBAR -->
    <div class="col-md-3 mb-4">
        {{> admin-sidebar activeSection='settings'}}
    </div>

    <!-- CONTENT -->
    <div class="col-md-9">
      <div class="card shadow-sm border-0">
        
        <!-- Header -->
        <div class="card-header bg-white border-bottom py-3">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold text-danger">
                <i class="bi bi-gear-fill me-2"></i> SYSTEM SETTINGS
            </h5>
            <span class="badge bg-danger-subtle text-danger px-3 py-2">Configuration</span>
          </div>
        </div>
        
        <!-- Body -->
        <div class="card-body p-4">
          {{#if error_message}}
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <i class="bi bi-exclamation-triangle-fill me-2"></i> {{error_message}}
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
          {{/if}}

          <!-- Description -->
          <div class="alert alert-info border-0 mb-4">
              <i class="bi bi-info-circle-fill me-2"></i>
              <strong>Important:</strong> These settings control critical auction system behaviors. Please make changes carefully.
          </div>

          <form id="formSystemSettings" method="POST" action="/admin/system/settings">
            
            <div class="row g-4">
              
              {{> admin/setting-card 
                    icon="bi-clock-history" title="New Product Limit" description="Defines how long (in minutes) a product is considered 'new'..."
                    inputIcon="bi-stopwatch" inputText="Duration" inputId="txtNewProductLimit" inputName="new_product_limit_minutes" 
                    value=settings.new_product_limit_minutes max="10080" hint="Recommended: 60-1440 minutes (1 hour to 1 day)"
                }}

                {{> admin/setting-card 
                    icon="bi-lightning-charge" title="Auto Extend Trigger" description="When a bid is placed within this many minutes before auction end..."
                    inputIcon="bi-alarm" inputText="Trigger Time" inputId="txtAutoExtendTrigger" inputName="auto_extend_trigger_minutes" 
                    value=settings.auto_extend_trigger_minutes max="60" hint="Recommended: 5-15 minutes before end"
                }}

                {{> admin/setting-card 
                    icon="bi-arrow-clockwise" title="Auto Extend Duration" description="How many minutes to extend the auction when auto-extend is triggered."
                    inputIcon="bi-plus-circle" inputText="Extension" inputId="txtAutoExtendDuration" inputName="auto_extend_duration_minutes" 
                    value=settings.auto_extend_duration_minutes max="120" hint="Recommended: 5-30 minutes extension"
                }}
            </div>

            <!-- Action Buttons -->
            <div class="d-flex gap-2 mt-4 pt-4 border-top mb-4">
              <button type="submit" class="btn btn-lg px-5 btn-admin-primary">
                <i class="bi bi-check-circle me-2"></i>Save Changes
              </button>
              <a href="/admin/dashboard" class="btn btn-outline-secondary btn-lg px-4 btn-admin-secondary">
                <i class="bi bi-x-circle me-2"></i>Cancel
              </a>
            </div>
          </form>

        </div>
        
      </div>
    </div>

  </div>
</div>
