<div class="container-fluid mt-4 mb-5">
  <div class="row">
    
    {{!-- LEFT SIDEBAR --}}
    <div class="col-lg-3 mb-4">
        {{> seller-sidebar activeSection='dashboard'}}
    </div>

    {{!-- RIGHT CONTENT --}}
    <div class="col-lg-9">

      {{!-- WELCOME MESSAGE --}}
      <div class="mb-4">
        <h2 class="fw-bold mb-1">Dashboard Overview</h2>
        <p class="text-muted">Welcome back, <strong>{{authUser.fullname}}</strong>! Here's your selling performance at a glance.</p>
      </div>

      {{!-- STATS CARDS --}}
      <div class="row g-4 mb-4">      
        {{> seller/dashboard/stat-card title="Total" value=stats.total_products icon="bi-box-seam" color="text-primary"}}
        {{> seller/dashboard/stat-card title="Active" value=stats.active_products icon="bi-play-circle" color="text-success"}}
        {{> seller/dashboard/stat-card title="Pending" value=stats.pending_products icon="bi-hourglass-split" color="text-warning"}}
        {{> seller/dashboard/stat-card title="Sold" value=stats.sold_products icon="bi-bag-check" color="text-info"}}
        {{> seller/dashboard/stat-card title="Expired" value=stats.expired_products icon="bi-x-circle" color="text-secondary"}}
      </div>

      {{!-- REVENUE STATS --}}
      <div class="row g-4 mb-4">
        {{> seller/dashboard/revenue-card title="Pending Revenue" value=(format_number stats.pending_revenue) icon="bi-hourglass-split" color="text-warning"}}       
        {{> seller/dashboard/revenue-card title="Potential Revenue" value=(format_number stats.total_revenue) icon="bi-cash-coin" color="text-primary" borderClass="border-primary border-2"}}  
        {{> seller/dashboard/revenue-card title="Completed Revenue" value=(format_number stats.completed_revenue) icon="bi-check-circle" color="text-success"}}
      </div>
      {{!-- QUICK START --}}
      <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
          <i class="bi bi-rocket-takeoff fs-1 text-primary mb-3 d-block"></i>
          <h5 class="mb-3">Ready to sell more?</h5>
          <p class="text-muted mb-4">Start by adding a new product or manage your existing listings</p>
          <div class="d-flex justify-content-center gap-2 flex-wrap">
            <a href="/seller/products/add" class="btn btn-primary btn-lg">
              <i class="bi bi-plus-circle"></i> Add New Product
            </a>
            <a href="/seller/products" class="btn btn-outline-primary btn-lg">
              <i class="bi bi-list"></i> Manage Products
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
